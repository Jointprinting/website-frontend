# ──────────────────────────────────────────────────────────────
# Lantern Barn — environment variables
# Copy this file to ".env.local" and fill in the values.
# In Vercel, add the same keys under Project → Settings → Environment Variables.
# The site runs fine with sample content even if these are left blank.
# ──────────────────────────────────────────────────────────────

# Sanity (the CMS the owner uses to edit events, photos & text)
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
# Optional: an API version date, leave as-is unless you know otherwise
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01

# Square (online store / checkout). Get these from the Square Developer dashboard.
# Use the SANDBOX values while testing, then swap to PRODUCTION before launch.
SQUARE_ACCESS_TOKEN=
SQUARE_LOCATION_ID=
SQUARE_ENVIRONMENT=sandbox

# Where contact-form submissions are emailed (used by /api/contact)
CONTACT_TO_EMAIL=hello@lanternbarn.com
# Resend API key for sending the contact email (https://resend.com — free tier)
RESEND_API_KEY=

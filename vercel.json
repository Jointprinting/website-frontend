{
  "headers": [
    {
      "source": "/_nfc/(.*)",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow, noarchive" },
        { "key": "Content-Type", "value": "text/vcard; charset=utf-8" }
      ]
    },
    {
      "source": "/webworks(/.*)?",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" },
        { "key": "Cache-Control", "value": "no-store, max-age=0, must-revalidate" }
      ]
    }
  ],
  "redirects": [
    { "source": "/demos", "destination": "/webworks" },
    { "source": "/demos/:path*", "destination": "/webworks/:path*" },
    { "source": "/northpine", "destination": "/webworks/northpine" },
    { "source": "/clearwater", "destination": "/webworks/clearwater" }
  ]
}
